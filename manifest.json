{
  "manifest_version": 3,
  "name": "Complicated Onboarding",
  "description": "Split a chosen task's time into 90-minute timelogs on a given date.",
  "version": "1.0.0",
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_title": "Split timelog",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png"
    }
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://new.simpleonboarding.com.au/*"]
}